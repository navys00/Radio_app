{
  "name": "expo-cli",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "validate:audio": "node ./scripts/validate-audio.cjs",
    "validate": "npm run validate:audio && npm run typecheck",
    "prebuild:android": "expo prebuild --platform android --no-install",
    "build:android:apk": "npm run validate && npm run prebuild:android && cd android && gradlew.bat assembleRelease",
    "build:android:apk:cloud": "eas build --platform android --profile preview"
  },
  "dependencies": {
    "@expo-google-fonts/oswald": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.13",
    "expo-av": "~16.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
